# Credenciais usadas pelas skills. Copie para `.env` e preencha.
# NUNCA comite o .env (já está no .gitignore). Como obter cada uma:
# .claude/skills/coletar-dados-funil/references/credenciais.md

# --- Meta / Business Manager (funil de marketing) ---
META_ACCOUNT=act_000000000000      # ID da conta de anúncios (act_ + número)
META_TOKEN=                        # access token com ads_read

# --- CRM (funil comercial) — opcional, varia por CRM ---
# O caminho universal é exportar CSV e usar crm_csv.py (sem token).
CRM_API_TOKEN=
